    {
      "ruleId": "semantic.collection.living-characters",
      "match": {
        "nodeKind": "collection",
        "property": "pointer",
        "equals": "$.living"
      },
      "claim": {
        "semanticName": "living_character_collection",
        "semanticKind": "collection_name",
        "proposition": "The collection at $.living contains records for living characters.",
        "status": "proposed",
        "confidence": 0.78,
        "docTopic": "Characters",
        "uncertainty": {
          "level": "medium",
          "reasons": [
            "The path name and record volume strongly suggest character records, but this initial rule does not yet inspect installed game definitions."
          ]
        },
        "notes": [
          "Do not create one durable node per character."
        ]
      }
    },
