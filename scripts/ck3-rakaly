#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$ROOT_DIR/state/rakaly-cli/rakaly-0.8.17-x86_64-unknown-linux-musl"
BIN="$BIN_DIR/rakaly"

if [[ ! -x "$BIN" ]]; then
  printf 'rakaly binary not found or not executable: %s\n' "$BIN" >&2
  exit 1
fi

exec "$BIN" "$@"
