#!/usr/bin/env node
import fs from 'node:fs';
import path from 'node:path';
import { discoverStructure } from './lib/json-structure-discovery.mjs';
import { IdentityReferenceCollector } from './lib/ck3-identity-references.mjs';

function printHelp() {
  console.log(`Usage: ck3-save-references <path-to-json-or-json.gz> --collections PATH [options]

Streams a Rakaly JSON artifact and a candidate collection catalog to emit
identity-domain observations and aggregate reference candidates. It does not
name CK3 semantics; it only records value-to-domain evidence.

Options:
  --collections PATH     Candidate collection catalog from ck3-save-collections
  --source-id ID         Attach a source registry ID to the output
  --out PATH             Write output JSON to PATH (default: stdout)
  --quiet                Suppress progress on stderr
`);
}

function parseArgs(argv) {
  const args = {
    input: null,
    collections: null,
    sourceId: null,
    out: null,
    quiet: false,
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    switch (a) {
      case '--collections':
        args.collections = argv[++i];
        break;
      case '--source-id':
        args.sourceId = argv[++i];
        break;
      case '--out':
        args.out = argv[++i];
        break;
      case '--quiet':
      case '-q':
        args.quiet = true;
        break;
      case '--help':
      case '-h':
        printHelp();
        process.exit(0);
        break;
      default:
        if (a.startsWith('--')) {
          console.error(`Unknown flag: ${a}`);
          process.exit(2);
        }
        if (args.input) {
          console.error(`Unexpected positional arg: ${a}`);
          process.exit(2);
        }
        args.input = a;
    }
  }
  return args;
}

async function main() {
  const args = parseArgs(process.argv.slice(2));
  if (!args.input || !args.collections) {
    printHelp();
    process.exit(2);
  }
  if (!fs.existsSync(args.input)) {
    console.error(`Input file not found: ${args.input}`);
    process.exit(2);
  }
  if (!fs.existsSync(args.collections)) {
    console.error(`Collections file not found: ${args.collections}`);
    process.exit(2);
  }

  const collectionCatalog = JSON.parse(fs.readFileSync(args.collections, 'utf8'));
  if (!Array.isArray(collectionCatalog.candidateCollections)) {
    console.error('Collections input is missing candidateCollections');
    process.exit(2);
  }

  const collector = new IdentityReferenceCollector(collectionCatalog);
  const start = Date.now();
  const parseResult = await discoverStructure({
    source: args.input,
    collector,
    onProgress: args.quiet
      ? null
      : (p) => {
          const mb = (p.bytesProcessed / 1024 / 1024).toFixed(1);
          const rssMb = (p.rssBytes / 1024 / 1024).toFixed(0);
          process.stderr.write(`  ${mb} MB processed (${rssMb} MB RSS, ${p.elapsedMs} ms)\n`);
        },
  });
  const result = collector.result();
  const elapsed = Date.now() - start;

  const output = {
    schemaVersion: 1,
    source: {
      path: path.resolve(args.input),
      sourceId: args.sourceId ?? collectionCatalog.source?.sourceId ?? null,
      collectionsCatalogPath: path.resolve(args.collections),
    },
    summary: result.summary,
    identityDomains: result.identityDomains,
    referenceCandidates: result.referenceCandidates,
    ambiguityReport: result.ambiguityReport,
    diagnostics: {
      durationMs: elapsed,
      parseDurationMs: parseResult.diagnostics.durationMs,
      peakRssBytes: parseResult.diagnostics.peakRssBytes,
      bytesProcessed: parseResult.diagnostics.bytesProcessed,
    },
  };

  const json = JSON.stringify(output, null, 2) + '\n';
  if (args.out) {
    fs.mkdirSync(path.dirname(path.resolve(args.out)), { recursive: true });
    fs.writeFileSync(args.out, json);
    if (!args.quiet) {
      process.stderr.write(
        `Wrote ${output.summary.identityDomains} identity domains / ${output.summary.referenceCandidates} reference candidates to ${args.out} in ${elapsed} ms\n`,
      );
    }
  } else {
    process.stdout.write(json);
  }
}

main().catch((err) => {
  console.error(err.stack || err.message);
  process.exit(2);
});
