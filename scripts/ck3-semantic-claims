#!/usr/bin/env node
import fs from 'node:fs';
import path from 'node:path';
import {
  buildSemanticComparisonReport,
  generateSemanticClaims,
  validateClaimLedger,
} from './lib/ck3-semantic-claims.mjs';

function printHelp() {
  console.log(`Usage: ck3-semantic-claims generate --graph PATH --rules PATH --sources PATH [options]

Generates semantic claim proposals from durable schema graph patterns. This
command never reads raw save artifacts and never mutates structural graph
observations.

Options:
  --claims-out PATH      Write claim ledger JSON
  --report-out PATH      Write comparison/report JSON
  --quiet                Suppress progress on stderr
`);
}

function parseArgs(argv) {
  const args = {
    subcommand: argv[0] ?? null,
    graph: null,
    rules: null,
    sources: null,
    claimsOut: null,
    reportOut: null,
    quiet: false,
  };
  for (let i = 1; i < argv.length; i++) {
    const a = argv[i];
    switch (a) {
      case '--graph':
        args.graph = argv[++i];
        break;
      case '--rules':
        args.rules = argv[++i];
        break;
      case '--sources':
        args.sources = argv[++i];
        break;
      case '--claims-out':
        args.claimsOut = argv[++i];
        break;
      case '--report-out':
        args.reportOut = argv[++i];
        break;
      case '--quiet':
      case '-q':
        args.quiet = true;
        break;
      case '--help':
      case '-h':
        printHelp();
        process.exit(0);
        break;
      default:
        console.error(`Unknown argument: ${a}`);
        printHelp();
        process.exit(2);
    }
  }
  return args;
}

function readJson(label, filePath) {
  if (!filePath) {
    console.error(`Missing required --${label}`);
    process.exit(2);
  }
  if (!fs.existsSync(filePath)) {
    console.error(`${label} file not found: ${filePath}`);
    process.exit(2);
  }
  return JSON.parse(fs.readFileSync(filePath, 'utf8'));
}

function writeJson(filePath, data) {
  fs.mkdirSync(path.dirname(path.resolve(filePath)), { recursive: true });
  fs.writeFileSync(filePath, JSON.stringify(data, null, 2) + '\n');
}

function main() {
  const args = parseArgs(process.argv.slice(2));
  if (args.subcommand !== 'generate') {
    printHelp();
    process.exit(args.subcommand ? 2 : 0);
  }
  const graph = readJson('graph', args.graph);
  const rules = readJson('rules', args.rules);
  const sourceRegistry = readJson('sources', args.sources);
  const ledger = generateSemanticClaims({ graph, rules, sourceRegistry });
  const errors = validateClaimLedger(ledger, graph);
  if (errors.length > 0) {
    console.error(`Generated claim ledger failed validation:\n- ${errors.join('\n- ')}`);
    process.exit(1);
  }
  const report = buildSemanticComparisonReport({ ledger, graph });
  if (args.claimsOut) writeJson(args.claimsOut, ledger);
  if (args.reportOut) writeJson(args.reportOut, report);
  if (!args.claimsOut && !args.reportOut) {
    process.stdout.write(JSON.stringify({ ledger, report }, null, 2) + '\n');
  } else if (!args.quiet) {
    process.stderr.write(`Generated ${ledger.claims.length} semantic claims\n`);
  }
}

main();
