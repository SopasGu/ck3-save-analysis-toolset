#!/usr/bin/env node
import fs from 'node:fs';
import path from 'node:path';
import {
  augmentClaimsWithPerTopicSources,
  buildProposedClaim,
  buildSemanticComparisonReport,
  generateSemanticClaims,
  mergeProposedClaims,
  promoteClaim,
  validateClaimLedger,
} from './lib/ck3-semantic-claims.mjs';

function printHelp() {
  console.log(`Usage:
  ck3-semantic-claims generate --graph PATH --rules PATH --sources PATH [options]
  ck3-semantic-claims propose  --claims PATH --graph PATH --sources PATH --proposed PATH [options]
  ck3-semantic-claims promote  --claims PATH --claim-id ID --to STATUS [--superseded-by ID]...
  ck3-semantic-claims augment  --claims PATH --sources PATH [--section-first-only]

Generate, propose, promote, and augment semantic claims. None of these commands
mutate structural graph observations.

generate options:
  --claims-out PATH      Write claim ledger JSON
  --report-out PATH      Write comparison/report JSON
  --quiet                Suppress progress on stderr

propose options:
  --proposed PATH        JSON array of proposed claim entries (operator-authored)
  --out PATH             Where to write the merged ledger (default: in-place --claims)
  --overwrite            Replace existing claims with matching claimId
  --quiet                Suppress progress on stderr

promote options:
  --claim-id ID          Claim to update
  --to STATUS            Target status (must be a member of CLAIM_STATUSES)
  --superseded-by ID     One or more claim IDs that supersede this one
  --review-note TEXT     Free-text review note
  --out PATH             Where to write the updated ledger (default: in-place --claims)
  --quiet                Suppress progress on stderr

augment options:
  --sources PATH         Source registry path
  --section-first-only   When present, emit a single 'section' anchor field per topic
  --out PATH             Where to write the augmented ledger (default: in-place --claims)
  --quiet                Suppress progress on stderr
`);
}

function parseArgs(argv) {
  const args = {
    subcommand: null,
    graph: null,
    rules: null,
    sources: null,
    claimsPath: null,
    claimsOut: null,
    reportOut: null,
    proposed: null,
    overwrite: false,
    claimIdValue: null,
    toStatus: null,
    supersededBy: [],
    reviewNote: null,
    sectionFirstOnly: false,
    quiet: false,
  };
  const knownSubcommands = new Set(['generate', 'propose', 'promote', 'augment']);
  let flagStart = 0;
  if (argv.length > 0 && knownSubcommands.has(argv[0])) {
    args.subcommand = argv[0];
    flagStart = 1;
  }
  for (let i = flagStart; i < argv.length; i++) {
    const a = argv[i];
    switch (a) {
      case '--graph':
        args.graph = argv[++i];
        break;
      case '--rules':
        args.rules = argv[++i];
        break;
      case '--sources':
        args.sources = argv[++i];
        break;
      case '--claims':
        args.claimsPath = argv[++i];
        break;
      case '--claims-out':
        args.claimsOut = argv[++i];
        break;
      case '--report-out':
        args.reportOut = argv[++i];
        break;
      case '--proposed':
        args.proposed = argv[++i];
        break;
      case '--out':
        args.claimsOut = argv[++i];
        break;
      case '--overwrite':
        args.overwrite = true;
        break;
      case '--claim-id':
        args.claimIdValue = argv[++i];
        break;
      case '--to':
        args.toStatus = argv[++i];
        break;
      case '--superseded-by':
        args.supersededBy.push(argv[++i]);
        break;
      case '--review-note':
        args.reviewNote = argv[++i];
        break;
      case '--section-first-only':
        args.sectionFirstOnly = true;
        break;
      case '--quiet':
      case '-q':
        args.quiet = true;
        break;
      case '--help':
      case '-h':
        printHelp();
        process.exit(0);
        break;
      default:
        console.error(`Unknown argument: ${a}`);
        printHelp();
        process.exit(2);
    }
  }
  return args;
}

function readJson(label, filePath) {
  if (!filePath) {
    console.error(`Missing required --${label}`);
    printHelp();
    process.exit(2);
  }
  if (!fs.existsSync(filePath)) {
    console.error(`${label} file not found: ${filePath}`);
    process.exit(2);
  }
  return JSON.parse(fs.readFileSync(filePath, 'utf8'));
}

function writeJson(filePath, data) {
  fs.mkdirSync(path.dirname(path.resolve(filePath)), { recursive: true });
  fs.writeFileSync(filePath, JSON.stringify(data, null, 2) + '\n');
}

function cmdGenerate(args) {
  const graph = readJson('graph', args.graph);
  const rules = readJson('rules', args.rules);
  const sourceRegistry = readJson('sources', args.sources);
  const ledger = generateSemanticClaims({ graph, rules, sourceRegistry });
  const errors = validateClaimLedger(ledger, graph);
  if (errors.length > 0) {
    console.error(`Generated claim ledger failed validation:\n- ${errors.join('\n- ')}`);
    process.exit(1);
  }
  const report = buildSemanticComparisonReport({ ledger, graph });
  if (args.claimsOut) writeJson(args.claimsOut, ledger);
  if (args.reportOut) writeJson(args.reportOut, report);
  if (!args.quiet) {
    if (args.claimsOut) console.error(`Generated ${ledger.claims.length} semantic claims -> ${args.claimsOut}`);
    if (args.reportOut) console.error(`Wrote comparison report -> ${args.reportOut}`);
  }
  if (!args.claimsOut && !args.reportOut) {
    process.stdout.write(JSON.stringify({ ledger, report }, null, 2) + '\n');
  }
}

function cmdPropose(args) {
  const ledger = readJson('claims', args.claimsPath);
  const graph = readJson('graph', args.graph);
  const sourceRegistry = readJson('sources', args.sources);
  const proposed = readJson('proposed', args.proposed);
  const built = proposed.map((entry) => buildProposedClaim({
    entry,
    graph,
    sourceRegistry,
    generatedAt: new Date().toISOString(),
  }));
  const merged = mergeProposedClaims(ledger, built, { overwrite: args.overwrite });
  const errors = validateClaimLedger(merged, graph);
  if (errors.length > 0) {
    console.error(`Proposed claim merge failed validation:\n- ${errors.join('\n- ')}`);
    process.exit(1);
  }
  const outPath = args.claimsOut ?? args.claimsPath;
  writeJson(outPath, merged);
  if (!args.quiet) {
    console.error(`Proposed ${built.length} claims (added=${(merged.proposedAdded ?? []).length}, skipped=${(merged.proposedSkipped ?? []).length}) -> ${outPath}`);
  }
}

function cmdPromote(args) {
  if (!args.claimIdValue) {
    console.error('promote requires --claim-id');
    process.exit(2);
  }
  if (!args.toStatus) {
    console.error('promote requires --to STATUS');
    process.exit(2);
  }
  const ledger = readJson('claims', args.claimsPath);
  const next = promoteClaim(ledger, args.claimIdValue, args.toStatus, {
    supersededBy: args.supersededBy,
    reviewNote: args.reviewNote,
  });
  const errors = validateClaimLedger(next);
  if (errors.length > 0) {
    console.error(`Promote failed validation:\n- ${errors.join('\n- ')}`);
    process.exit(1);
  }
  const outPath = args.claimsOut ?? args.claimsPath;
  writeJson(outPath, next);
  if (!args.quiet) {
    console.error(`Promoted ${args.claimIdValue}: ${next.previousStatus} -> ${args.toStatus} -> ${outPath}`);
  }
}

function cmdAugment(args) {
  const ledger = readJson('claims', args.claimsPath);
  const sourceRegistry = readJson('sources', args.sources);
  const augmented = augmentClaimsWithPerTopicSources(ledger, sourceRegistry, {
    sectionFirstOnly: args.sectionFirstOnly,
  });
  const errors = validateClaimLedger(augmented);
  if (errors.length > 0) {
    console.error(`Augmented ledger failed validation:\n- ${errors.join('\n- ')}`);
    process.exit(1);
  }
  const outPath = args.claimsOut ?? args.claimsPath;
  writeJson(outPath, augmented);
  if (!args.quiet) {
    console.error(`Augmented ${augmented.augmented ?? 0} claims with per-topic documentation sources -> ${outPath}`);
  }
}

function main() {
  const args = parseArgs(process.argv.slice(2));
  switch (args.subcommand) {
    case 'generate':
      cmdGenerate(args);
      return;
    case 'propose':
      cmdPropose(args);
      return;
    case 'promote':
      cmdPromote(args);
      return;
    case 'augment':
      cmdAugment(args);
      return;
    default:
      printHelp();
      process.exit(args.subcommand ? 2 : 0);
  }
}

main();
