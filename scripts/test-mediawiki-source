#!/usr/bin/env node
import {
  buildMediaWikiRegistryEntry,
  buildMediaWikiTopicRegistryEntry,
  selectMediaWikiTopicGroup,
  sourceIdForMediaWikiPage,
  summarizeMediaWikiLinks,
  summarizeMediaWikiTopicPage,
} from './lib/ck3-mediawiki-source.mjs';

let failed = 0;

function ok(label) {
  console.log(`OK    ${label}`);
}

function fail(label, detail) {
  console.error(`FAIL  ${label}`);
  if (detail) console.error(detail);
  failed++;
}

function fixtureSource(extra = {}) {
  return {
    sourceId: 'source:ck3-paradoxwikis-com:main-page-links',
    kind: 'mediawiki_page',
    site: {
      key: 'ck3.paradoxwikis.com',
      sitename: 'CK3 Wiki',
      generator: 'MediaWiki 1.39.4',
      apiUrl: 'https://ck3.paradoxwikis.com/api.php',
      server: 'https://ck3.paradoxwikis.com',
      articlePath: '/$1',
      rights: {
        url: 'https://central.paradoxwikis.com/Central:Copyrights',
        text: 'Attribution-ShareAlike 3.0',
      },
    },
    page: {
      title: 'Main Page/links',
      pageId: 1217,
      canonicalUrl: 'https://ck3.paradoxwikis.com/Main_Page/links',
      revisionId: 34070,
      parentRevisionId: 33252,
      revisionTimestamp: '2026-03-31T15:22:48Z',
      revisionSha1: 'bc27c8066b15f94e64c1129e145403c0e844100c',
      oldidUrl: 'https://ck3.paradoxwikis.com/Main_Page/links?oldid=34070',
      length: 12345,
    },
    links: [
      { title: "Beginner's guide", url: 'https://ck3.paradoxwikis.com/Beginner%27s_guide' },
      { title: 'Characters', url: 'https://ck3.paradoxwikis.com/Characters' },
      { title: 'Culture', url: 'https://ck3.paradoxwikis.com/Culture' },
      { title: 'Faith', url: 'https://ck3.paradoxwikis.com/Faith' },
      { title: 'Adventurer', url: 'https://ck3.paradoxwikis.com/Adventurer' },
      { title: 'Downloadable content', url: 'https://ck3.paradoxwikis.com/Downloadable_content' },
    ],
    sectionAnchors: [
      { index: '1', toplevel: 1, anchor: 'Overview', line: 'Overview' },
      { index: '2', toplevel: 1, anchor: 'Culture_management', line: 'Culture management' },
      { index: '3', toplevel: 2, anchor: 'Innovations', line: 'Innovations' },
    ],
    requestPolicy: {
      userAgent: 'test-agent',
      minDelayMs: 1200,
      concurrency: 1,
      cacheDir: '/tmp/cache',
      retryAfterHonored: true,
    },
    ...extra,
  };
}

function testSourceId() {
  const id = sourceIdForMediaWikiPage('ck3.paradoxwikis.com', 'Main Page/links');
  if (id !== 'source:ck3-paradoxwikis-com:main-page-links') {
    fail('mediawiki sourceId is stable and readable', id);
    return;
  }
  ok('mediawiki sourceId is stable and readable');
}

function testSummaryGroups() {
  const summary = summarizeMediaWikiLinks(fixtureSource());
  if (
    summary.gettingStarted[0]?.title !== "Beginner's guide" ||
    summary.characterSystems[0]?.title !== 'Characters' ||
    summary.cultureFaith.length !== 2 ||
    summary.governance[0]?.title !== 'Adventurer'
  ) {
    fail('main links grouped into seed mechanics topics', JSON.stringify(summary, null, 2));
    return;
  }
  ok('main links grouped into seed mechanics topics');
}

function testRegistryEntryScopeAndCitation() {
  const entry = buildMediaWikiRegistryEntry(fixtureSource(), {
    allDlcActive: true,
    gameVersions: ['1.19.0.6'],
    acquiredAt: '2026-07-17T21:00:00-07:00',
  });
  if (entry.scope.allDlcActive !== true || !entry.scope.dlc.includes('ALL_ACTIVE_ASSUMPTION')) {
    fail('registry entry records all-DLC-active scope', JSON.stringify(entry.scope));
    return;
  }
  if (entry.oldidUrl !== 'https://ck3.paradoxwikis.com/Main_Page/links?oldid=34070') {
    fail('registry entry preserves oldid citation URL', entry.oldidUrl);
    return;
  }
  if (entry.content.copiedContent !== 'metadata_and_link_titles_only') {
    fail('registry entry preserves the link-titles-only copiedContent label', JSON.stringify(entry.content));
    return;
  }
  if (entry.extracted.sectionAnchorCount !== 3) {
    fail('registry entry records section anchor count', JSON.stringify(entry.extracted));
    return;
  }
  ok('registry entry records all-DLC scope, citation, section anchor count, and metadata-only copied content');
}

function testTopicPageSummaryAndEntry() {
  const topicSource = fixtureSource({
    page: {
      title: 'Culture',
      pageId: 42,
      canonicalUrl: 'https://ck3.paradoxwikis.com/Culture',
      revisionId: 200,
      parentRevisionId: 199,
      revisionTimestamp: '2026-04-01T00:00:00Z',
      revisionSha1: 'abcd1234567890',
      oldidUrl: 'https://ck3.paradoxwikis.com/Culture?oldid=200',
      length: 4096,
    },
    sectionAnchors: [
      { index: '0', toplevel: 1, anchor: 'Overview', line: 'Overview' },
      { index: '1', toplevel: 1, anchor: 'Culture_management', line: 'Culture management' },
      { index: '2', toplevel: 2, anchor: 'Innovations', line: 'Innovations' },
    ],
    links: [],
  });
  const summary = summarizeMediaWikiTopicPage(topicSource);
  if (summary.pageTitle !== 'Culture' || summary.sectionAnchors.length !== 3) {
    fail('topic summary carries title and section anchors', JSON.stringify(summary));
    return;
  }
  if (summary.sectionAnchors[2].line !== 'Innovations') {
    fail('topic summary preserves section ordering', JSON.stringify(summary.sectionAnchors));
    return;
  }
  const entry = buildMediaWikiTopicRegistryEntry(topicSource, {
    topic: 'Culture',
    allDlcActive: true,
    gameVersions: ['1.19.0.6'],
  });
  if (entry.topic !== 'Culture') {
    fail('topic registry entry records topic label', JSON.stringify(entry));
    return;
  }
  if (entry.content.copiedContent !== 'metadata_and_section_anchors_only') {
    fail('topic entry uses metadata-only copiedContent', JSON.stringify(entry.content));
    return;
  }
  if (entry.extracted.sectionAnchors.some((s) => s.line.includes(' lead ') || /\bthe\b/i.test(s.line))) {
    if (entry.content.copiedContent !== 'metadata_and_section_anchors_only') {
      fail('topic entry stores section anchor titles, not lead text', JSON.stringify(entry));
      return;
    }
  }
  ok('topic-page summarizer + topic registry entry store metadata and section anchors only');
}

function testTopicGroupSelection() {
  if (selectMediaWikiTopicGroup('Culture') !== 'cultureFaith') {
    fail('Culture maps to cultureFaith', selectMediaWikiTopicGroup('Culture'));
    return;
  }
  if (selectMediaWikiTopicGroup('Patches') !== 'documentationMeta') {
    fail('Patches maps to documentationMeta', selectMediaWikiTopicGroup('Patches'));
    return;
  }
  if (selectMediaWikiTopicGroup('NotInAnyGroup') !== null) {
    fail('Unknown page returns null topic group', selectMediaWikiTopicGroup('NotInAnyGroup'));
    return;
  }
  ok('topic group selector classifies pages deterministically');
}

console.log('ck3-mediawiki-source self-test');
console.log('==============================');

testSourceId();
testSummaryGroups();
testRegistryEntryScopeAndCitation();
testTopicPageSummaryAndEntry();
testTopicGroupSelection();

if (failed > 0) {
  console.error(`\n${failed} test(s) failed`);
  process.exit(1);
}
console.log('\nAll mediawiki-source tests passed');
