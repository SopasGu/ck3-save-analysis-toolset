#!/usr/bin/env node
import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { execFileSync } from 'node:child_process';

let failed = 0;

function ok(label) {
  console.log(`OK    ${label}`);
}

function fail(label, detail) {
  console.error(`FAIL  ${label}`);
  if (detail) console.error(detail);
  failed++;
}

function syntheticSave() {
  return {
    date: '872.5.18',
    played_character: { character: 101 },
    living: {
      '101': {
        first_name: 'Test Adventurer',
        birth: '850.1.1',
        culture: 1,
        faith: 2,
        skill: [4, 9, 5, 6, 3, 12],
        trait: ['brave', 'adventurer'],
        alive_data: {
          location: { location: 1001 },
          gold: { value: 42 },
          prestige: { currency: 88 },
          piety: { currency: 15 },
          influence: { currency: 0 },
          perk: ['stalwart_leader_perk'],
        },
        landed_data: {
          government: 'landless_adventurer_government',
          laws: ['camp_purpose_mercenaries'],
          succession: [102],
          domain: [],
        },
      },
      '102': {
        first_name: 'Follower',
        birth: '855.1.1',
        culture: 1,
        faith: 2,
        skill: [2, 3, 4, 5, 6, 7],
        court_data: { employer: 101 },
        alive_data: {},
        landed_data: {},
      },
      '201': {
        first_name: 'Patron',
        birth: '830.1.1',
        culture: 1,
        faith: 2,
        skill: [8, 8, 8, 8, 8, 8],
        alive_data: { gold: { value: 150 }, location: { location: 1002 } },
        landed_data: { government: 'feudal_government', domain: [301] },
      },
    },
    culture_manager: { cultures: { '1': { name: 'Test Culture' } } },
    religion: { faiths: { '2': { tag: 'test_faith' } } },
    landed_titles: {
      landed_titles: {
        '301': { key: 'c_test', holder: 201, title_name_data: { name: 'Test County' }, capital: 1002 },
      },
    },
    provinces: {
      '1001': { holding: { type: 'castle_holding' } },
      '1002': { holding: { type: 'castle_holding' } },
    },
    task_contracts: {
