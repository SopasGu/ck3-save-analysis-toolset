function withTempSave(fn) {
  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'ck3-report-consumers-'));
  const savePath = path.join(dir, 'save.json');
  fs.writeFileSync(savePath, JSON.stringify(syntheticSave(), null, 2));
  try {
    fn(savePath);
  } finally {
    fs.rmSync(dir, { recursive: true, force: true });
  }
}

function runReport(args) {
  return execFileSync(process.execPath, ['scripts/ck3-save-report', ...args], { encoding: 'utf8' });
}

function testBriefJsonParity() {
  withTempSave((savePath) => {
    const legacy = JSON.parse(runReport(['brief', savePath, '--json']));
    const migrated = JSON.parse(runReport(['brief', savePath, '--json', '--advisor-context']));
    if (JSON.stringify(legacy) !== JSON.stringify(migrated.brief)) {
      fail('brief consumer context preserves baseline brief JSON', JSON.stringify({ legacy, migrated: migrated.brief }, null, 2));
      return;
    }
    ok('brief consumer context preserves baseline brief JSON');
  });
}

function testBriefConsumerContext() {
  withTempSave((savePath) => {
    const migrated = JSON.parse(runReport(['brief', savePath, '--json', '--advisor-context']));
    const context = migrated.advisorConsumerContext;
    if (context?.report !== 'brief' || context.epistemicLayer !== 'E consumers') {
      fail('brief consumer context identifies report and layer', JSON.stringify(context, null, 2));
      return;
    }
    if (context.route.advisorId !== 'adventurer-contracts') {
      fail('brief consumer context routes landless brief to adventurer model', JSON.stringify(context.route));
      return;
    }
    if (!context.advisorModel.graphIds.length || !context.advisorModel.sourceIds.includes('source:ck3-paradoxwikis-com:adventurer')) {
      fail('brief consumer context carries graph IDs and mechanics source IDs', JSON.stringify(context.advisorModel, null, 2));
      return;
    }
    if (!context.reportGrounding.currentSaveEvidence.some((entry) => entry.reportField === 'brief.travelOpportunities.count' && entry.savePath === '$.task_contracts.database')) {
      fail('brief consumer context cites save path evidence for report fields', JSON.stringify(context.reportGrounding, null, 2));
      return;
    }
    if (context.comparison.changedFields.length || context.comparison.discrepancies.length) {
      fail('brief consumer context classifies no discrepancies for parity pilot', JSON.stringify(context.comparison, null, 2));
      return;
    }
    ok('brief consumer context cites advisor model, graph IDs, sources, and save evidence');
  });
}

function testBriefTextContext() {
  withTempSave((savePath) => {
    const output = runReport(['brief', savePath, '--advisor-context']);
    if (!output.includes('## Advisor Consumer Context') || !output.includes('brief.travelOpportunities.count -> $.task_contracts.database')) {
      fail('brief text report prints advisor consumer context', output);
      return;
    }
    ok('brief text report prints advisor consumer context');
  });
}

console.log('ck3-report-consumers self-test');
console.log('==============================');

testBriefJsonParity();
testBriefConsumerContext();
testBriefTextContext();

if (failed > 0) {
  console.error(`\n${failed} test(s) failed`);
  process.exit(1);
}
console.log('\nAll report-consumer tests passed');
